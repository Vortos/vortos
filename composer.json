{
    "name": "vortos/vortos",
    "description": "The Vortos Clean Architecture Framework — project skeleton",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "alpha",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "vortos/vortos-framework": "^1.0",
        "vortos/vortos-docker": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "suggest": {
        "vortos/vortos-docker": "Docker environment for local development"
    },
    "scripts": {
        "post-create-project-cmd": [
            "cp .env.example .env"
        ]
    }
}
