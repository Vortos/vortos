function normalizeSectionName(string $name): string
{
    return strtolower((string) preg_replace('/[^a-z0-9]+/i', '-', trim($name)));
}

function showCommandList(?string $sectionFilter = null): int
{
    $sections = commandSections();
    $filter = $sectionFilter !== null ? normalizeSectionName($sectionFilter) : null;
    $matched = false;

    echo PHP_EOL;
    echo bold('Vortos Commands') . '  ' . dim('php vortos <command> [options]') . PHP_EOL;
    echo dim('Use "php vortos list --raw" for the full console command list.') . PHP_EOL;
    echo PHP_EOL;

    foreach ($sections as $section => $data) {
        $sectionKey = normalizeSectionName($section);

        if ($filter !== null && $filter !== $sectionKey) {
            continue;
        }

        $matched = true;
        echo bold($section) . '  ' . dim($data['description']) . PHP_EOL;

        foreach ($data['commands'] as $cmd => $desc) {
            echo commandLine($cmd, $desc);
        }

        echo PHP_EOL;
    }

    if (!$matched && $filter !== null) {
        $available = implode(', ', array_map(normalizeSectionName(...), array_keys($sections)));
        fwrite(STDERR, red('Error:') . ' Unknown command section "' . $sectionFilter . '".' . PHP_EOL);
        fwrite(STDERR, dim('Available sections: ' . $available) . PHP_EOL);
        return 1;
    }

    return 0;
}

