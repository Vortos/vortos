#!/usr/bin/env php
<?php

declare(strict_types=1);

// ─── Config ──────────────────────────────────────────────────────────────────

const CONTAINER = 'backend';

// ─── Colours (disabled when not a TTY) ───────────────────────────────────────

$tty = stream_isatty(STDOUT);

function c(string $code, string $text): string
{
    global $tty;
    return $tty ? "\033[{$code}m{$text}\033[0m" : $text;
}

function green(string $s): string
{
    return c('32', $s);
}
function yellow(string $s): string
{
    return c('33', $s);
}
function red(string $s): string
{
    return c('31', $s);
}
function bold(string $s): string
{
    return c('1',  $s);
}
function dim(string $s): string
{
    return c('2',  $s);
}

// ─── Helpers ─────────────────────────────────────────────────────────────────

function isWindows(): bool
{
    return PHP_OS_FAMILY === 'Windows';
}

function nullDevice(): string
{
    return isWindows() ? 'NUL' : '/dev/null';
}

function quiet(string $cmd): string
{
    return $cmd . ' 2>' . nullDevice();
}

function phpBinary(): string
{
    return PHP_BINARY !== '' ? escapeshellarg(PHP_BINARY) : 'php';
}

function consoleCommand(string $command, string $args = ''): string
{
    return trim(phpBinary() . ' bin/console ' . $command . ' ' . $args);
}

function isDockerRunning(): bool
{
    exec(quiet('docker compose ps --status running -q ' . CONTAINER), $out, $code);
    return $code === 0 && !empty(array_filter($out));
}

function hostUserOption(): string
{
    if (isWindows()) {
        return '';
    }

    if (function_exists('posix_getuid') && function_exists('posix_getgid')) {
        return '-u ' . posix_getuid() . ':' . posix_getgid();
    }

    $uid = trim((string) shell_exec(quiet('id -u')));
    $gid = trim((string) shell_exec(quiet('id -g')));

    return $uid !== '' && $gid !== '' ? '-u ' . $uid . ':' . $gid : '';
}

function terminalColumns(): int
{
    $columns = getenv('COLUMNS');
    if (is_string($columns) && ctype_digit($columns) && (int) $columns > 0) {
        return (int) $columns;
    }

    if (isWindows()) {
        return 220;
    }

    $columns = trim((string) shell_exec(quiet('tput cols')));
    return ctype_digit($columns) && (int) $columns > 0 ? (int) $columns : 220;
}

function announce(string $where, string $cmd): void
{
    fwrite(STDERR, dim('> ') . green('Running') . ' ' . bold($where) . dim(': ') . rtrim($cmd) . PHP_EOL);
    fflush(STDERR);
}

function run(string $cmd, bool $interactive = false, ?string $where = null): int
{
    if ($where !== null) {
        announce($where, $cmd);
    }

    passthru($cmd, $code);
    return (int) $code;
}

function local(string $cmd): int
{
    return run($cmd, where: 'locally');
}

function docker(string $cmd, bool $interactive = false): int
{
    $flag = $interactive ? '-it' : '-t';
    $parts = array_filter([
        'docker compose exec',
        $flag,
        hostUserOption(),
        '-e TERM=xterm-256color',
        '-e COLUMNS=' . terminalColumns(),
        CONTAINER,
        $cmd,
    ]);

    return run(implode(' ', $parts), $interactive, 'Docker container ' . CONTAINER);
}

function compose(string $cmd): int
{
    return run(trim('docker compose ' . $cmd), where: 'host Docker');
}

function abort(string $msg, int $code = 1): never
{
    fwrite(STDERR, red('Error:') . ' ' . $msg . PHP_EOL);
    exit($code);
}

function warn(string $msg): void
{
    echo yellow('⚠') . ' ' . $msg . PHP_EOL;
}

function commandLine(string $cmd, string $desc): string
{
    return '  ' . str_pad(green($cmd), 42) . dim($desc) . PHP_EOL;
}

