// ─── Bootstrap ───────────────────────────────────────────────────────────────

$argv    = $_SERVER['argv'];
$args    = array_slice($argv, 1);
$command = $args[0] ?? null;
$rest    = array_slice($args, 1);
$restStr = implode(' ', array_map('escapeshellarg', $rest));

if ($command === null || in_array($command, ['--help', '-h'], true) || ($command === 'help' && $rest === [])) {
    showHelp();
    exit(0);
}

$docker = isDockerRunning();

// ─── Commands ────────────────────────────────────────────────────────────────

switch ($command) {

    case 'up':
        if ($docker) {
            warn('Environment is already running.');
        } else {
            exit(compose('up -d'));
        }
        break;

    case 'down':
        exit(compose('down ' . $restStr));

    case 'restart':
        compose('down');
        exit(compose('up -d'));

    case 'logs':
        exit(compose('logs -f ' . $restStr));

    case 'ps':
    case 'status':
        exit(compose('ps ' . $restStr));

    case 'docker':
        if (empty($rest)) {
            abort('Specify a docker compose command. Example: php vortos docker build');
        }
        exit(compose($restStr));

    case 'bash':
    case 'shell':
        if (!$docker) {
            warn('Docker is not running — you are already in your local shell.');
            break;
        }
        exit(docker('bash', interactive: true));

    case 'composer':
        if (empty($rest)) {
            abort('Specify a Composer command. Example: php vortos composer require vendor/package');
        }
        $cmd = 'composer ' . $restStr;
        exit($docker ? docker($cmd) : local($cmd));

    case 'test':
    case 'tests':
        $cmd = 'vendor/bin/phpunit ' . $restStr;
        exit($docker ? docker($cmd) : local($cmd));

    case 'help':
        $target = (string) ($rest[0] ?? '');
        $target = str_starts_with($target, 'vortos:') || in_array($target, ['completion', 'help', 'list'], true)
            ? $target
            : 'vortos:' . $target;
        $dockerCmd = 'php bin/console help ' . escapeshellarg($target) . ' --ansi';
        $localCmd = consoleCommand('help', escapeshellarg($target) . ' --ansi');
        exit($docker ? docker($dockerCmd) : local($localCmd));

    case 'completion':
        $dockerCmd = trim('php bin/console completion ' . $restStr);
        $localCmd = consoleCommand('completion', $restStr);
        exit($docker ? docker($dockerCmd) : local($localCmd));

    case 'list':
        if (in_array('--raw', $rest, true)) {
            $rawRest = array_values(array_filter($rest, fn(string $arg): bool => $arg !== '--raw'));
            $rawRestStr = implode(' ', array_map('escapeshellarg', $rawRest));
            $dockerCmd = trim('php bin/console list ' . $rawRestStr . ' --ansi');
            $localCmd = consoleCommand('list', trim($rawRestStr . ' --ansi'));
            exit($docker ? docker($dockerCmd) : local($localCmd));
        }

        $section = $rest[0] ?? null;
        exit(showCommandList($section));

    default:
        // Normalise: strip any leading "vortos:" then re-add it once.
        // Both forms work:
        //   php vortos make:entity User        → vortos:make:entity
        //   php vortos vortos:make:entity User → vortos:make:entity
        $console = 'vortos:' . (str_starts_with($command, 'vortos:') ? substr($command, 7) : $command);
        $ansi    = str_contains($restStr, '--no-ansi') ? '' : '--ansi';
        $dockerCmd = 'php bin/console ' . escapeshellarg($console) . ' ' . $restStr . ' ' . $ansi;
        $localCmd = consoleCommand(escapeshellarg($console), trim($restStr . ' ' . $ansi));

        if ($docker) {
            $exitCode = docker($dockerCmd);
        } elseif (PHP_BINARY !== '') {
            $exitCode = local($localCmd);
        } else {
            abort('PHP not found locally and Docker is not running.');
        }

        exit($exitCode);
}
